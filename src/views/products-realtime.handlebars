<div class="flex__container">
    <div>
        <h3 class="title">Productos</h3>
        <div id="products__container">
            <ul id="products__list"></ul>
        </div>
    </div>
    <div>
        <h3 class="title">Añadir productos al stock</h3>
        <div id="form__prods__container">
            <form id="form__prods">
                <label>Nombre:</label><input type="text" name="title" id="input__prod__title">
                <label>Precio:</label><input type="number" name="price" id="input__prod__price">
                <label>Stock:</label><input type="number" name="price" id="input__prod__stock">
                <input id="add__prod" type="submit" value="Añadir">
            </form>
        </div>
    </div>
</div>


<script src="/socket.io/socket.io.js"></script>
<script src="/js/products-realtime.js"></script>